{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dashboard",
  "baseBranchPatterns": ["devel"],
  "assignees": ["artur"],
  "labels": ["renovate"],
  "configMigration": true,
  "prHourlyLimit": 0,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": "* 0-9 * * *",
    "automerge": true
  },
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Manage container images with Ansible and Podman Quadlets",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker",
      "managerFilePatterns": ["/\\.ya?ml$/"],
      "matchStrings": [
        "(?<indentation>^\\s*)image:\\s*(?<depName>[a-zA-Z0-9./_-]+)(?::(?<currentValue>[a-zA-Z0-9._-]+))?(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      "autoReplaceStringTemplate": "{{{indentation}}}image: {{{depName}}}{{#if newValue}}:{{{newValue}}}{{/if}}{{#if newDigest}}@{{{newDigest}}}{{/if}}"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["ghcr.io/searxng/searxng"],
      "versioning": "regex:^(?<major>\\d{4})\\.(?<minor>\\d{1,2})\\.(?<patch>\\d{1,2})(?:-(?<build>[0-9a-fA-F]+))?$"
    },
    {
      "matchPackageNames": ["docker.io/postgres"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "matchPackageNames": ["docker.io/redis"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    // {
    //   "matchPackageNames": ["docker.io/getmeili/meilisearch"],
    //   "matchUpdateTypes": ["major"],
    //   "enabled": false
    // },
    {
      "matchPackageNames": ["docker.io/mongo"],
      "matchUpdateTypes": ["minor", "major"],
      "enabled": false
    },
    {
      "matchUpdateTypes": ["patch", "digest"],
      "matchCurrentVersion": "/^v?0/",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "ignoreTests": true
    },
    {
      "matchUpdateTypes": ["digest", "patch", "minor"],
      "matchCurrentVersion": "!/^v?0/",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "ignoreTests": true
    }
  ]
}
