# Keys
# Required key for platform encryption/decryption ops
ENCRYPTION_KEY={{ deploy_infisical_encryption_key }}

# JWT
# Required secrets to sign JWT tokens
AUTH_SECRET={{ deploy_infisical_auth_secret }}

# Postgres creds
POSTGRES_PASSWORD={{ deploy_infisical_postgres_password }}
POSTGRES_USER=infisical
POSTGRES_DB=infisical

# Required for rootless Podman
PGUSER=infisical

# Required
DB_CONNECTION_URI=postgres://infisical:{{ deploy_infisical_postgres_password }}@localhost:5432/infisical

# Redis
REDIS_URL=redis://localhost:6379

# Website URL
# Required
SITE_URL={{ deploy_infisical_site_url }}

TELEMETRY_ENABLED=false

# SMPT
SMTP_HOST=smtp.migadu.com
SMTP_PORT=465
SMTP_USERNAME={{ deploy_infisical_smtp_username }}
SMTP_PASSWORD={{ deploy_infisical_smtp_password }}
SMTP_FROM_ADDRESS={{ deploy_infisical_smtp_from_address }}
SMTP_FROM_NAME=Infisical
