{{ ansible_managed | comment }}
[Unit]
Description=Forgejo runner
After=network.target

[Service]
User={{ forgejo_runner__user }}
Group={{ forgejo_runner__group }}
WorkingDirectory={{ forgejo_runner__user_home }}
ExecStart={{ forgejo_runner__full_executable_path }} {{ forgejo_runner__mode }} -c {{ forgejo_runner__user_home }}/runner-config.yml
ExecReload=/bin/kill -s HUP $MAINPID
Restart=on-failure
TimeoutSec=0
RestartSec=10s

[Install]
WantedBy=multi-user.target
